            "choix": [
                {
                    "texte": "Chercher Émelyne",

                    "message": {
                        "personnage": "narrateur",
                        "texte": "Tu décides de chercher Émelyne avant le début des cours."
                    },

                    "condition": {
                        "variable": "rencontreEmelyne",
